__pycache__/
*.py[cod]
.pytest_cache/

# .NET build output from the demo project
demo/**/bin/
demo/**/obj/


# Internal working documents — machine paths, private project names,
# and notes written for a private audience. Kept locally, never committed.
docs/plans/

# Local tooling and editor state. Ignore .claude/ contents but keep the
# project-local skills subtree — a trailing-slash `.claude/` would stop git
# descending at all, so the re-includes below would never fire.
.claude/*
!.claude/skills/
.vscode/
.idea/

# Never commit secrets or local overrides
.env
.env.*
*.local

# OS noise
.DS_Store
Thumbs.db
