{
  "description": "Warn at session start when this plugin's dependencies are missing or broken.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/tools/check_fsharp_lsp.py\" --hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
