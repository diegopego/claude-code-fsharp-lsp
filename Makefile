# Developer entry points for claude-code-fsharp-lsp.
#
# The plugin itself is standard-library Python + one .lsp.json; these targets
# are conveniences, not build steps. `pytest` is invoked as `python3 -m pytest`
# because it is not on PATH as a bare command (see CLAUDE.md).

PYTHON ?= python3
SKILL  := .claude/skills/maintain-docs
DEMO   := demo/LibraryLending.slnx

.DEFAULT_GOAL := help
.PHONY: help test check gate refresh demo demo-clean clean docs

help:  ## List the available targets
	@grep -hE '^[a-zA-Z_-]+:.*?## ' $(MAKEFILE_LIST) \
		| awk 'BEGIN{FS=":.*?## "}{printf "  \033[1m%-11s\033[0m %s\n", $$1, $$2}'

test:  ## Run the Python test suite (~1s, no .NET needed)
	$(PYTHON) -m pytest

check:  ## Is the environment usable? (fsautocomplete on PATH, SDKs)
	$(PYTHON) tools/check_fsharp_lsp.py

gate:  ## Is the installed plugin byte-identical to this working tree?
	$(PYTHON) $(SKILL)/check_plugin_current.py

refresh:  ## Push this working tree into the installed plugin (RESTART after)
	$(PYTHON) $(SKILL)/refresh_plugin.py

demo:  ## Build the F# demo project (the documentation instrument)
	dotnet build $(DEMO)

demo-clean:  ## Remove the demo build output
	rm -rf demo/*/bin demo/*/obj

clean: demo-clean  ## Remove caches and build output
	rm -rf .pytest_cache
	find . -name __pycache__ -type d -prune -exec rm -rf {} +

docs:  ## How to regenerate README + landing page (Claude-driven, not a make step)
	@echo "Docs are regenerated by the maintain-docs skill, which captures real"
	@echo "tool output against demo/ and cannot run headless. In Claude Code:"
	@echo ""
	@echo "  1. make refresh   # only if you changed .lsp.json / skills/ / tools/"
	@echo "  2. restart the session"
	@echo "  3. /maintain-docs"
