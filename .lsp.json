{
  "fsharp": {
    "command": "python3",
    "args": ["${CLAUDE_PLUGIN_ROOT}/tools/fsac_sync_proxy.py", "fsautocomplete"],
    "extensionToLanguage": {
      ".fs": "fsharp",
      ".fsi": "fsharp",
      ".fsx": "fsharp"
    },
    "transport": "stdio",
    "initializationOptions": {
      "AutomaticWorkspaceInit": true
    },
    "settings": {
      "FSharp": {}
    },
    "diagnostics": true,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
